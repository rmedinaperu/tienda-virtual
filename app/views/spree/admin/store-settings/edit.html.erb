<% content_for :page_title do %>
  <%= I18n.t('spree.store_settings') %>
<% end %>

<%= form_for [:admin, @store], url: admin_store_settings_path, html: { multipart: true } do |f| %>
  <fieldset class="no-border-top">
    <div data-hook="admin_store_settings_form_fields">
      <div class="row">
        <div class="col-12 col-md-6">
          <div class="form-group">
            <%= f.label :logo, I18n.t('spree.logo') %>
            <br>
            <% if @store.logo.attached? %>
              <%= image_tag main_app.url_for(@store.logo), style: "max-height: 100px; margin-bottom: 10px;" %>
              <br>
            <% end %>
            <%= f.file_field :logo %>
          </div>
        </div>

        <div class="col-12 col-md-6">
          <div class="form-group">
            <%= f.label :favicon, I18n.t('spree.favicon') %>
            <br>
            <% if @store.favicon.attached? %>
              <%= image_tag main_app.url_for(@store.favicon), style: "max-height: 32px; margin-bottom: 10px;" %>
              <br>
            <% end %>
            <%= f.file_field :favicon %>
          </div>
        </div>
      </div>
    </div>

    <div class="form-actions" data-hook="buttons">
      <%= render partial: 'spree/admin/shared/edit_resource_links', locals: { collection_url: admin_store_settings_path } %>
    </div>
  </fieldset>
<% end %>
